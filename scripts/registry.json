[
  {
    "id": "ningbo-bank-training-export",
    "name": "宁波银行训练营学习时长导出",
    "description": "每周导出宁波银行训练营的学习时长数据，包含课程总时长、已完成时长、完成进度",
    "category": "宁波银行",
    "tags": [
      "学习时长",
      "训练营",
      "周报"
    ],
    "script": "宁波银行/导出训练营学习时长.py",
    "params": [
      {
        "name": "assess_id",
        "label": "测评ID",
        "type": "string",
        "required": true,
        "description": "训练营关联的测评ID"
      },
      {
        "name": "date_range",
        "label": "日期范围",
        "type": "daterange",
        "required": false,
        "default": "last_week"
      }
    ],
    "output": {
      "type": "excel",
      "filename_pattern": "宁波银行训练营学习时长_{date}.xlsx"
    },
    "dependencies": [
      "requests",
      "openpyxl"
    ],
    "estimated_time": "30s-2min",
    "requires_auth": [
      "ARCHERY_COOKIE",
      "SAAS_TOKEN"
    ]
  },
