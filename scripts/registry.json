    "tags": [
      "试题",
      "导出",
      "题库"
    ],
    "script": "内部需求/试题库导出.py",
    "params": [
      {
        "name": "subject",
        "label": "科目",
        "type": "select",
        "required": false,
        "options": [
          {
            "label": "全部",
            "value": "all"
          },
          {
            "label": "金融",
            "value": "finance"
          },
          {
            "label": "合规",
            "value": "compliance"
          },
          {
            "label": "信息技术",
            "value": "it"
          }
        ],
        "default": "all"
      },
      {
        "name": "limit",
        "label": "导出数量",
        "type": "number",
        "required": false,
        "default": 1000,
        "description": "最大导出数量，留空表示全部"
      }
    ],
    "output": {
      "type": "excel",
      "filename_pattern": "试题库导出_{date}.xlsx"
    },
    "estimated_time": "1-3min",
    "requires_auth": [
      "ARCHERY_COOKIE"
    ]
  },
