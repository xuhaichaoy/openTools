{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HiClow",
  "version": "0.1.0",
  "identifier": "com.51cto.toolbox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5180",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "HiClow",
        "width": 800,
        "height": 60,
        "minWidth": 800,
        "minHeight": 60,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https: http:; img-src 'self' data: blob: https:; font-src 'self' data:; frame-src 'self' null:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "plugins/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDQjUyRkExMjRENzJEREUKUldUZUxkY2tvUysxakNEcFE5bnFpemtYS0E3ZnFJeUtSTEIyYVBZRXV3clQzenAwNzl1b240WmwK",
      "endpoints": [
        "https://your-HiClow-server.com/v1/app/update"
      ]
    }
  }
}