# 数据库连接
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mtools

# Redis 连接（用于验证码、缓存）
REDIS_URL=redis://localhost:6379

# JWT 密钥（生产环境请使用随机的长字符串）
JWT_SECRET=change_me_to_a_random_secret

# 服务端口
PORT=3000

# 部署模式: public（公共服务）| private（私有部署）
DEPLOY_MODE=private

# CORS 允许的 Origin（逗号分隔），留空或 * 表示全部允许
# ALLOWED_ORIGINS=https://app.example.com,tauri://localhost

# API Key 加密密钥（Base64 编码的 32 字节密钥）
# 生成方式: openssl rand -base64 32
# 不设置时使用开发环境 fallback 密钥（生产环境必须设置！）
# ENCRYPTION_KEY=
