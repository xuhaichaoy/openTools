# ── 数据库 ──────────────────────────────────────────────────────────────────
# 生产环境（docker-compose.prod.yml）中 DATABASE_URL 会被自动覆盖为容器服务名
# 本地开发时使用 docker-compose.yml 启动的 PG（端口 5433）
DATABASE_URL=postgres://postgres:postgres@localhost:5433/mtools

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# 生产环境必须修改！生成命令: openssl rand -hex 64
JWT_SECRET=change_me_to_a_random_secret

# ── 服务 ─────────────────────────────────────────────────────────────────────
PORT=3000

# 部署模式: public（公共服务）| private（私有部署）
DEPLOY_MODE=private

# 上传目录（生产环境建议绝对路径或挂载卷路径）
UPLOAD_DIR=./uploads

# ── CORS ─────────────────────────────────────────────────────────────────────
# 逗号分隔，留空或 * 表示全部允许
# ALLOWED_ORIGINS=https://your-domain.com,tauri://localhost

# ── 加密密钥 ─────────────────────────────────────────────────────────────────
# !! 生产环境必须设置，且一旦设置不可更改（否则已加密的 API Key 无法解密）!!
# 生成命令: openssl rand -base64 32
# ENCRYPTION_KEY=

# ── PostgreSQL 密码（docker-compose.prod.yml 使用）───────────────────────────
# 生产环境必须修改！生成命令: openssl rand -hex 16
POSTGRES_PASSWORD=postgres

# ── 日志级别 ─────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── App 自动更新（可选）──────────────────────────────────────────────────────
# 不配置时 /v1/app/update 接口返回 204，客户端静默忽略
# APP_LATEST_VERSION=1.0.0
# APP_RELEASE_DATE=2026-02-26T00:00:00Z
# APP_RELEASE_NOTES=修复若干问题并提升稳定性
# APP_RELEASE_BASE_URL=https://your-cdn.com/releases
# APP_SIG_DARWIN_AARCH64=
# APP_SIG_DARWIN_X86_64=
# APP_SIG_WINDOWS_X86_64=
# APP_SIG_LINUX_X86_64=
